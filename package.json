{
  "name": "freenary",
  "version": "0.9.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "migration:generate": "bun node_modules/typeorm/cli.js -- -d configurations/ormConfig.ts migration:generate ./migrations/auto",
    "migration:run": "bun node_modules/typeorm/cli.js migration:run -d ./configurations/ormConfig.ts",
    "migration:revert": "set TS_NODE_PROJECT=tsconfig.typeorm.json&& bun ./node_modules/typeorm/cli.js migration:revert -d configurations/ormConfig.ts"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "dotenv": "^17.2.3",
    "jsdom": "^27.4.0",
    "next": "^16.2.1",
    "react": "~19.2.3",
    "react-dom": "~19.2.3",
    "react-minimal-pie-chart": "^9.1.2",
    "reflect-metadata": "^0.2.2",
    "sqlite3": "^5.1.7",
    "ts-node": "^10.9.2",
    "typeorm": "^0.3.28",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jsdom": "^27.0.0",
    "@types/node": "^25.0.10",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^10.1.0",
    "eslint-config-next": "^0.2.4",
    "tailwindcss": "^4",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5"
  },
  "overrides": {
    "tar": "^7.5.13",
    "@tootallnate/once": "^3.0.1"
  }
}